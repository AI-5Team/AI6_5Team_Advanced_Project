{
  "version": "draft-v1",
  "status": "proposal",
  "nonBreaking": true,
  "goal": "Map current scene slots and text roles into hook/body/cta layers without changing existing template runtime.",
  "layerDefinitions": [
    {
      "slotGroup": "hook",
      "description": "첫 1~2초 안에 주목을 끄는 한 줄 또는 인상적인 첫 문장"
    },
    {
      "slotGroup": "body",
      "description": "상품, 혜택, 차별점, 방문 이유처럼 설득을 담당하는 중간 정보 블록"
    },
    {
      "slotGroup": "cta",
      "description": "행동 유도와 마무리를 담당하는 마지막 블록"
    }
  ],
  "textRoleToLayer": {
    "hook": {
      "slotGroup": "hook",
      "bodySubtype": null,
      "uiLabel": "후킹 문장"
    },
    "region_hook": {
      "slotGroup": "hook",
      "bodySubtype": null,
      "uiLabel": "지역 후킹 문장"
    },
    "review_quote": {
      "slotGroup": "hook",
      "bodySubtype": null,
      "uiLabel": "후기 후킹 문장"
    },
    "product_name": {
      "slotGroup": "body",
      "bodySubtype": "product",
      "uiLabel": "상품 소개"
    },
    "difference": {
      "slotGroup": "body",
      "bodySubtype": "difference",
      "uiLabel": "차별점"
    },
    "benefit": {
      "slotGroup": "body",
      "bodySubtype": "benefit",
      "uiLabel": "혜택"
    },
    "urgency": {
      "slotGroup": "body",
      "bodySubtype": "urgency",
      "uiLabel": "긴급성"
    },
    "visit_reason": {
      "slotGroup": "body",
      "bodySubtype": "reason",
      "uiLabel": "방문 이유"
    },
    "cta": {
      "slotGroup": "cta",
      "bodySubtype": null,
      "uiLabel": "행동 유도"
    }
  },
  "templates": [
    {
